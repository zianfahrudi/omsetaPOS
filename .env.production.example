APP_NAME=omsetaPOS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.omseta.web.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Database (container MySQL). DB_HOST = nama service di docker-compose (jangan diubah).
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=omsetapos
DB_USERNAME=omseta
DB_PASSWORD=omseta-zian-ganteng
# Hanya dipakai container MySQL untuk inisialisasi root.
DB_ROOT_PASSWORD=omseta-zian-ganteng

# Password user awal saat `db:seed` (WAJIB kuat, bukan 'password' — seeder menolak default).
SEED_PASSWORD=omseta-zian-ganteng
SEED_SUPERUSER_EMAIL=admin@omseta.web.id

# HTTPS aktif di produksi → cookie hanya via HTTPS.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Email: default log (tidak kirim nyata). Isi SMTP bila perlu kirim email.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@omseta.web.id"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
