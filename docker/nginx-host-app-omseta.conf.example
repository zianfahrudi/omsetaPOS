# Reverse proxy nginx HOST (Ubuntu) → container omsetaPOS.
# Domain: app.omseta.web.id  |  VPS khusus projek ini.
#
# Pasang:
#   sudo cp docker/nginx-host-app-omseta.conf.example /etc/nginx/sites-available/app.omseta.web.id
#   sudo ln -s /etc/nginx/sites-available/app.omseta.web.id /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d app.omseta.web.id      # pasang HTTPS (blok 443 ditambah otomatis)

server {
    listen 80;
    listen [::]:80;
    server_name app.omseta.web.id;

    # certbot akan menambah redirect ke 443 + sertifikat setelah dijalankan.
    location / {
        proxy_pass http://127.0.0.1:18080;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_read_timeout 120s;
        client_max_body_size 25M;
    }
}
