# Reverse proxy di nginx HOST VPS (bukan di dalam container).
# Simpan di /etc/nginx/sites-available/omseta.ziandev.site lalu symlink ke sites-enabled,
# atau /etc/nginx/conf.d/omseta.ziandev.site.conf. Jalankan: nginx -t && systemctl reload nginx.
#
# Sertifikat HTTPS: pakai certbot →
#   certbot --nginx -d omseta.ziandev.site

server {
    listen 80;
    listen [::]:80;
    server_name omseta.ziandev.site;

    # Diisi/diatur otomatis oleh certbot (redirect ke 443) setelah SSL terpasang.
    location / {
        proxy_pass http://127.0.0.1:18080;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_read_timeout 120s;
        client_max_body_size 25M;
    }
}
